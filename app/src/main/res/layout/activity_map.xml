<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- ═══════════════ MAIN CONTENT ═══════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#F0F4F0">

        <!-- TOOLBAR -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:background="#2E7D32"
            android:gravity="center_vertical"
            android:paddingStart="10dp"
            android:paddingEnd="12dp">

            <!-- Profile photo circle — tapping opens sidebar drawer -->
            <FrameLayout
                android:id="@+id/ivMenu"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless">

                <!-- Circle background -->
                <View
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:background="@drawable/avatar_circle_bg"/>

                <!-- Profile photo (shown when user sets one) -->
                <ImageView
                    android:id="@+id/ivProfilePhoto"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:scaleType="centerCrop"
                    android:visibility="gone"/>

                <!-- Initial letter (shown when no photo) -->
                <TextView
                    android:id="@+id/tvToolbarInitial"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:gravity="center"
                    android:text="U"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"/>
            </FrameLayout>

            <ImageView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginStart="8dp"
                android:src="@drawable/logo_find_cart"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="FindCartx1"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"/>

            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp">

                <ImageView
                    android:id="@+id/btnViewCart"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:src="@drawable/ic_cart"
                    app:tint="#FFFFFF"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless"/>

                <TextView
                    android:id="@+id/tvCartBadge"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="-4dp"
                    android:layout_marginEnd="-4dp"
                    android:background="@drawable/badge_circle"
                    android:gravity="center"
                    android:text="0"
                    android:textColor="#FFFFFF"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:visibility="gone"/>
            </FrameLayout>

            <ImageView
                android:id="@+id/ivHelp"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@android:drawable/ic_menu_help"
                app:tint="#FFFFFF"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"/>
        </LinearLayout>

        <!-- SEARCH BAR -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#388E3C"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingBottom="10dp"
            android:paddingTop="4dp">

            <EditText
                android:id="@+id/etSearch"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:background="@drawable/search_bg"
                android:drawableStart="@android:drawable/ic_menu_search"
                android:drawablePadding="6dp"
                android:hint="Search products, racks..."
                android:textSize="14sp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:inputType="text"
                android:imeOptions="actionSearch"
                android:singleLine="true"/>
        </LinearLayout>

        <!-- 3 TABS -->
        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tabLayout"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:background="#FFFFFF"
            app:tabIndicatorColor="#2E7D32"
            app:tabIndicatorHeight="3dp"
            app:tabSelectedTextColor="#2E7D32"
            app:tabTextColor="#757575"
            app:tabMode="fixed"
            app:tabGravity="fill">

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Products"/>

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ground Floor"/>

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1st Floor"/>
        </com.google.android.material.tabs.TabLayout>

        <!-- CATEGORY CHIPS -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="7dp"
            android:paddingBottom="7dp"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/chipContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"/>
        </HorizontalScrollView>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0"/>

        <!-- CONTENT FRAME -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- PRODUCTS TAB -->
            <ScrollView
                android:id="@+id/productView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#F0F4F0"
                android:visibility="visible">

                <GridLayout
                    android:id="@+id/productGrid"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="2"
                    android:padding="4dp"/>
            </ScrollView>

            <!-- GROUND FLOOR TAB -->
            <LinearLayout
                android:id="@+id/groundFloorView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:background="#C5CAE9"
                android:visibility="gone">

                <!-- Floor header bar -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="36dp"
                    android:background="#1565C0"
                    android:gravity="center_vertical"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Ground Floor — Tap any rack to browse items"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"/>
                </LinearLayout>

                <!-- Map + floating cart button stacked -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <!-- Map is built here in Java -->
                    <LinearLayout
                        android:id="@+id/groundMapContainer"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"/>

                    <!-- Floating Cart Button — bottom left (opposite to stairs which are bottom right) -->
                    <FrameLayout
                        android:id="@+id/fabCartGround"
                        android:layout_width="58dp"
                        android:layout_height="58dp"
                        android:layout_gravity="bottom|start"
                        android:layout_marginStart="14dp"
                        android:layout_marginBottom="14dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:elevation="6dp"
                        android:background="@drawable/badge_circle">

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_cart"
                            app:tint="#FFFFFF"/>

                        <TextView
                            android:id="@+id/tvFabBadgeGround"
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_gravity="top|end"
                            android:layout_marginTop="4dp"
                            android:layout_marginEnd="4dp"
                            android:background="@drawable/badge_circle"
                            android:gravity="center"
                            android:text="0"
                            android:textColor="#FFFFFF"
                            android:textSize="8sp"
                            android:textStyle="bold"
                            android:visibility="gone"/>
                    </FrameLayout>
                </FrameLayout>
            </LinearLayout>

            <!-- 1ST FLOOR TAB -->
            <LinearLayout
                android:id="@+id/firstFloorView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:background="#EDE7F6"
                android:visibility="gone">

                <!-- Floor header bar -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="36dp"
                    android:background="#6A1B9A"
                    android:gravity="center_vertical"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="1st Floor — Tap any rack to browse items"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"/>
                </LinearLayout>

                <!-- Map + floating cart button stacked -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <!-- Map is built here in Java -->
                    <LinearLayout
                        android:id="@+id/firstMapContainer"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"/>

                    <!-- Floating Cart Button — bottom left (opposite to stairs bottom right) -->
                    <FrameLayout
                        android:id="@+id/fabCartFirst"
                        android:layout_width="58dp"
                        android:layout_height="58dp"
                        android:layout_gravity="bottom|start"
                        android:layout_marginStart="14dp"
                        android:layout_marginBottom="14dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:elevation="6dp"
                        android:background="@drawable/badge_circle">

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_cart"
                            app:tint="#FFFFFF"/>

                        <TextView
                            android:id="@+id/tvFabBadgeFirst"
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_gravity="top|end"
                            android:layout_marginTop="4dp"
                            android:layout_marginEnd="4dp"
                            android:background="@drawable/badge_circle"
                            android:gravity="center"
                            android:text="0"
                            android:textColor="#FFFFFF"
                            android:textSize="8sp"
                            android:textStyle="bold"
                            android:visibility="gone"/>
                    </FrameLayout>
                </FrameLayout>
            </LinearLayout>

        </FrameLayout>
    </LinearLayout>

    <!-- ═══════════════ NAVIGATION DRAWER ═══════════════ -->
    <ScrollView
        android:layout_width="300dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="#FFFFFF"
        android:scrollbars="none"
        android:elevation="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- USER HEADER -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#2E7D32"
                android:orientation="vertical"
                android:padding="20dp"
                android:paddingTop="44dp">

                <FrameLayout
                    android:layout_width="72dp"
                    android:layout_height="72dp">
                    <View
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:background="@drawable/avatar_circle_bg"/>
                    <TextView
                        android:id="@+id/tvAvatarInitial"
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:gravity="center"
                        android:text="U"
                        android:textColor="#FFFFFF"
                        android:textSize="28sp"
                        android:textStyle="bold"/>
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Welcome back!"
                    android:textColor="#FFFFFF"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:layout_marginTop="10dp"/>

                <TextView
                    android:id="@+id/tvUserEmail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="user@findcartx1.com"
                    android:textColor="#C8E6C9"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp"/>

                <!-- Floor guide inside header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="14dp"
                    android:background="#1B5E20"
                    android:padding="10dp">
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Ground Floor" android:textColor="#FFFFFF"
                            android:textSize="11sp" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Food and Grocery" android:textColor="#A5D6A7" android:textSize="10sp"/>
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="1st Floor" android:textColor="#FFFFFF"
                            android:textSize="11sp" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Home and Lifestyle" android:textColor="#A5D6A7" android:textSize="10sp"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- OFFERS LABEL -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="TODAY'S OFFERS"
                android:textSize="10sp"
                android:textColor="#9E9E9E"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:padding="14dp"
                android:paddingBottom="6dp"
                android:background="#F5F5F5"/>

            <!-- Offer 1 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:background="#FFF8E1" android:padding="12dp"
                android:layout_marginStart="10dp" android:layout_marginEnd="10dp" android:layout_marginTop="6dp">
                <TextView android:layout_width="48dp" android:layout_height="48dp"
                    android:gravity="center" android:text="20%\nOFF" android:textSize="11sp"
                    android:textStyle="bold" android:textColor="#FFFFFF" android:background="#FF6F00"/>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="12dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="All Snacks and Chips" android:textSize="13sp"
                        android:textStyle="bold" android:textColor="#212121"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Valid Today Only" android:textSize="11sp" android:textColor="#FF6F00"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Offer 2 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:background="#E8F5E9" android:padding="12dp"
                android:layout_marginStart="10dp" android:layout_marginEnd="10dp" android:layout_marginTop="6dp">
                <TextView android:layout_width="48dp" android:layout_height="48dp"
                    android:gravity="center" android:text="BUY\n2+1" android:textSize="11sp"
                    android:textStyle="bold" android:textColor="#FFFFFF" android:background="#2E7D32"/>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="12dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="All Beverages" android:textSize="13sp"
                        android:textStyle="bold" android:textColor="#212121"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Min. 3 items" android:textSize="11sp" android:textColor="#388E3C"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Offer 3 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:background="#FCE4EC" android:padding="12dp"
                android:layout_marginStart="10dp" android:layout_marginEnd="10dp"
                android:layout_marginTop="6dp" android:layout_marginBottom="4dp">
                <TextView android:layout_width="48dp" android:layout_height="48dp"
                    android:gravity="center" android:text="Rs50\nOFF" android:textSize="11sp"
                    android:textStyle="bold" android:textColor="#FFFFFF" android:background="#C62828"/>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="12dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Orders above Rs500" android:textSize="13sp"
                        android:textStyle="bold" android:textColor="#212121"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Code: FCX1SAVE50" android:textSize="11sp" android:textColor="#C62828"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Offer 4 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:background="#EDE7F6" android:padding="12dp"
                android:layout_marginStart="10dp" android:layout_marginEnd="10dp"
                android:layout_marginTop="6dp" android:layout_marginBottom="4dp">
                <TextView android:layout_width="48dp" android:layout_height="48dp"
                    android:gravity="center" android:text="15%\nOFF" android:textSize="11sp"
                    android:textStyle="bold" android:textColor="#FFFFFF" android:background="#6A1B9A"/>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="12dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="1st Floor All Items" android:textSize="13sp"
                        android:textStyle="bold" android:textColor="#212121"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Electronics, Home and Care" android:textSize="11sp" android:textColor="#6A1B9A"/>
                </LinearLayout>
            </LinearLayout>

            <!-- DIVIDER -->
            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#E0E0E0" android:layout_marginTop="10dp"/>

            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="MENU" android:textSize="10sp" android:textColor="#9E9E9E"
                android:textStyle="bold" android:letterSpacing="0.15"
                android:paddingStart="16dp" android:paddingTop="10dp" android:paddingBottom="4dp"/>

            <!-- Profile -->
            <LinearLayout android:id="@+id/menuProfile"
                android:layout_width="match_parent" android:layout_height="52dp"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingStart="16dp" android:paddingEnd="16dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true" android:focusable="true">
                <ImageView android:layout_width="22dp" android:layout_height="22dp"
                    android:src="@drawable/ic_profile_icon" app:tint="#424242"/>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:layout_marginStart="16dp"
                    android:text="My Profile" android:textSize="15sp" android:textColor="#212121"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text=">" android:textSize="20sp" android:textColor="#BDBDBD"/>
            </LinearLayout>

            <!-- Offers -->
            <LinearLayout android:id="@+id/menuOffers"
                android:layout_width="match_parent" android:layout_height="52dp"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingStart="16dp" android:paddingEnd="16dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true" android:focusable="true">
                <ImageView android:layout_width="22dp" android:layout_height="22dp"
                    android:src="@android:drawable/ic_menu_agenda" app:tint="#FF6F00"/>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:layout_marginStart="16dp"
                    android:text="Offers and Deals" android:textSize="15sp" android:textColor="#212121"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="NEW" android:textSize="9sp" android:textColor="#FFFFFF"
                    android:textStyle="bold" android:background="#FF6F00"
                    android:paddingStart="7dp" android:paddingEnd="7dp"
                    android:paddingTop="3dp" android:paddingBottom="3dp"/>
            </LinearLayout>

            <!-- History -->
            <LinearLayout android:id="@+id/menuHistory"
                android:layout_width="match_parent" android:layout_height="52dp"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingStart="16dp" android:paddingEnd="16dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true" android:focusable="true">
                <ImageView android:layout_width="22dp" android:layout_height="22dp"
                    android:src="@android:drawable/ic_menu_recent_history" app:tint="#424242"/>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:layout_marginStart="16dp"
                    android:text="Purchase History" android:textSize="15sp" android:textColor="#212121"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text=">" android:textSize="20sp" android:textColor="#BDBDBD"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#E0E0E0" android:layout_marginTop="4dp"/>

            <!-- Logout -->
            <LinearLayout android:id="@+id/menuLogout"
                android:layout_width="match_parent" android:layout_height="52dp"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingStart="16dp" android:paddingEnd="16dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true" android:focusable="true">
                <ImageView android:layout_width="22dp" android:layout_height="22dp"
                    android:src="@android:drawable/ic_menu_close_clear_cancel" app:tint="#C62828"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginStart="16dp" android:text="Logout"
                    android:textSize="15sp" android:textColor="#C62828"/>
            </LinearLayout>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="FindCartx1 v2.0  ·  2 Floors  ·  150+ Products"
                android:textSize="10sp" android:textColor="#BDBDBD"
                android:padding="16dp" android:paddingTop="20dp"/>

        </LinearLayout>
    </ScrollView>

</androidx.drawerlayout.widget.DrawerLayout>